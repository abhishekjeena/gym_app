{
  "name": "gym-app-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "start": "npm start --workspace backend",
    "backend:start": "npm start --workspace backend",
    "backend:dev": "npm run dev --workspace backend",
    "backend:local": "npm run local --workspace backend",
    "backend:prod": "npm run prod --workspace backend",
    "frontend:dev": "npm run dev --workspace frontend",
    "frontend:build": "npm run build --workspace frontend"
  }
}
